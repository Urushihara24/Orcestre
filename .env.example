# ============================================================
# TELEGRAM BOT
# ============================================================
TELEGRAM_BOT_TOKEN=PUT_YOUR_TELEGRAM_BOT_TOKEN_HERE
ADMIN_TELEGRAM_ID=123456789
# Optional: multiple admins (comma/space separated). If set, it also includes ADMIN_TELEGRAM_ID.
# ADMIN_TELEGRAM_IDS=123456789,987654321

# ============================================================
# DATABASE
# ============================================================
# SQLite (simple/dev):
# DB_URL=sqlite:///./bot_data.db
#
# PostgreSQL (recommended):
DB_URL=postgresql+psycopg://egs_user:egs_pass@127.0.0.1:5432/egs_bot

# ============================================================
# PROCESSING
# ============================================================
MAX_TASKS_PER_TICK=10
PROCESS_TICK_SECONDS=20
DAILY_RESET_HOUR_UTC=0

# ============================================================
# DEFAULTS
# ============================================================
DEFAULT_DAILY_LIMIT=5
DEFAULT_SEND_JITTER_MIN_SEC=300
DEFAULT_SEND_JITTER_MAX_SEC=900
DEFAULT_TARGET_SENDERS_COUNT=1
DEFAULT_TIMEZONE=Europe/Moscow
DEFAULT_MIN_REQUEST_INTERVAL_SEC=30
DEFAULT_MAX_REQUEST_INTERVAL_SEC=40
DEFAULT_HOURLY_API_LIMIT=40
DEFAULT_DAILY_API_LIMIT=500
DEFAULT_RECHECK_DAILY_LIMIT=500
DAILY_REPEAT_CAMPAIGN_ENABLED=0
LOG_RETENTION_DAYS=30

DEVICE_AUTH_TIMEOUT_SEC=900
SEND_REQUESTS_ENABLED=0
ALLOW_SHOW_PASSWORD=0

# DRY_RUN=1 disables Epic network calls in queue worker (safe default for development).
# DRY_RUN=0 enables real Epic API calls in healthcheck and other flows that use device_auth.
DRY_RUN=1

# Optional: export device_auth to a JSON file (DB is primary storage).
# Leave empty to disable writing secrets to the repo folder.
DEVICE_AUTHS_JSON_PATH=

# Gate for password-only device auth generation (keep disabled if not needed)
ALLOW_PASSWORD_DEVICE_AUTH_BATCH=0

# Epic OAuth/app secrets (provide valid values)
EPIC_SWITCH_TOKEN=PUT_YOUR_EPIC_SWITCH_TOKEN_HERE
EPIC_ANDROID_TOKEN=PUT_YOUR_EPIC_ANDROID_TOKEN_HERE
EPIC_CLIENT_ID=PUT_YOUR_EPIC_CLIENT_ID_HERE
EPIC_CLIENT_SECRET=PUT_YOUR_EPIC_CLIENT_SECRET_HERE
